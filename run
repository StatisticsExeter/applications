#!/bin/bash
set -euo pipefail

function run_sp() {
    echo "Running unit tests on module code"
    pytest course/unsupervised_classification/tests/test_unsupervised_core.py
    echo "Running linter on Introduction to Python"
    flake8 course/unsupervised_classification/unsupervised_core.py --statistics && echo "No linting errors found in module code"
    flake8 course/scripts/stage_demo/ --statistics && echo "No linting errors found in stage script"
    dvc repro stage_demo_report
}

function run_demo() {
    echo "Running tests for Introduction to Python"
    pytest course/intro/tests/test_pipeline_functions.py
    echo "Running linter on Introduction to Python"
    flake8 course/intro --statistics && echo "No linting errors found in module code"
    flake8 course/scripts/intro --statistics && echo "No linting errors found in CLI script"
    echo "Checking for remaining TODOs in scripts"
    TODO_COUNT=$(grep -ri "TODO" course/scripts/intro | wc -l)
    if [ "$TODO_COUNT" -gt 0 ]; then
        echo "Found $TODO_COUNT remaining TODO(s) in your scripts."
        echo "Make sure you have moved the logic to the module code!"
        grep -rn "TODO" course/scripts/intro
    else
        echo "All TODOs cleared from scripts. Great refactoring!"
    fi
    echo "Running demonstration pipeline"
    dvc repro intro_demo --force --no-commit
}

function run_hello() {
    echo "Running Hello, World test file"
    pytest course/intro/tests/test_hello.py
}

function run_check() {
    python course/run_checks.py
}


function run_ex() {
    pytest course/exercises/tests/
    flake8 course/exercises/
}

function run_cwk() {
    echo "Running tests for coursework tasks"
    pytest course/supervised_classification/tests
    pytest course/regression/tests
    pytest course/unsupervised_classification/tests
    echo "Running linter on coursework tasks"
    flake8 course/supervised_classification
    flake8 course/unsupervised_classification
    flake8 course/regression
    echo "Running linter on scripts"
    flake8 course/scripts/*/*.py
}

function run_reports(){
    echo "Running live version of coursework tasks"
    dvc repro unsupervised_report
    dvc repro supervised_report
    dvc repro regression_report
}

function show_help() {
    echo "Usage: $0 <command>"
    echo
    echo "Available commands:"
    echo "  check        Run project checks, ensure your set up works"
    echo "  hello        Display greeting message"
    echo "  demo         Run demonstration pipeline"
    echo "  ex           Run exercises"
    echo "  sp           Run staged pipeline"
    echo "  cwk          Run tests and lint on coursework tasks"
    echo "  reports      Run live coursework tasks (needs database connection). Run in Anaconda prompt"
    echo "  help, --help Show this help message"
    echo
    echo "Example:"
    echo "  $0 demo"
}


case "${1:-help}" in
    help|--help|-h)
        show_help
        ;;
    check)
        run_check
        ;;
    hello)
        run_hello
        ;;
    ex)
        run_ex
        ;;
    sp)
        run_sp
        ;;
    cwk)
        run_cwk
        ;;
    demo)
        run_demo
        ;;
    reports)
        run_reports
        ;;
    *)
        echo "Error: Unknown command '$1'"
        echo "Run '$0 help' to see available commands."
        exit 1
        ;;
esac
